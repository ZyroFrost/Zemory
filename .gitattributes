# Encrypted sync bundles ride Git LFS (HP điều 7 — only .enc leaves the machine).
*.zemory.enc filter=lfs diff=lfs merge=lfs -text
global_memory.*.enc filter=lfs diff=lfs merge=lfs -text

# Binary assets: never EOL-normalize or text-diff them (the packaging/app icons).
*.png binary
*.ico binary
*.webmanifest text eol=lf

# Source + docs are stored LF so a Windows checkout can't reintroduce CRLF churn.
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
