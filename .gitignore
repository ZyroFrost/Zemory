node_modules/
dist/
.zemory/
.claude/*.local.json
*.db
*.db-*
*.sqlite
*.sqlite3
*.zemory.enc
# Delta/lean sync bundles are named global_memory.<host>.<seq>.enc — they do NOT
# match *.zemory.enc above, so ignore them explicitly (never let a PII bundle reach git).
global_memory.*.enc
# ...EXCEPT the repo's own share bundle — share/README documents it as the
# LFS-tracked sync artifact; without this exception it silently never commits.
!share/global_memory.zemory.enc
*.zemory.key
share/*.key
!share/share.key
.zemory-share.key
*.log
*.tgz
coverage/
data/
# web-capture (now in attic/): NEVER commit pulled chat data (PII) or dumps — code only
attic/web-capture/*.json
attic/web-capture/*.txt
